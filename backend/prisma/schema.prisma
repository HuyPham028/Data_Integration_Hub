// ============= EMPLOYEE DATA TABLES =============

/// Bảng lý lịch cán bộ
model TcnsLyLich {
  id                  Int      @id @default(autoincrement())
  shcc                String   @unique @db.VarChar(255)
  maNhanVien          String   @db.VarChar(20)
  ho                  String   @db.VarChar(150)
  ten                 String   @db.VarChar(50)
  ngaySinh            DateTime? @db.Timestamp()
  thanhPhanGiaDinh    String?  @db.VarChar(5)
  thanhPhanBanThan    String?  @db.VarChar(5)
  gioiTinh            String?  @db.VarChar(5)
  danToc              String?  @db.VarChar(5)
  tonGiao             String?  @db.VarChar(5)
  quocTich            String?  @db.VarChar(5)
  emailCaNhan         String?  @db.VarChar(70)
  chieuCao            Int?
  canNang             Int?
  nhomMau             String?  @db.VarChar(5)
  ngayNhapNgu         DateTime? @db.Timestamp()
  ngayXuatNgu         DateTime? @db.Timestamp()
  quanHam             String?  @db.VarChar(5)
  ngayVaoDang         DateTime? @db.Timestamp()
  ngayVaoDangCt       DateTime? @db.Timestamp()
  ngayVaoDoan         DateTime? @db.Timestamp()
  maSoThue            String?  @db.VarChar(20)
  stk                 String?  @db.VarChar(20)
  nganHang            String?  @db.VarChar(100)
  email               String?  @db.VarChar(70)
  chiNhanh            String?  @db.VarChar(200)
  biDanh              String?  @db.VarChar(100)
  cccd                String?  @db.VarChar(20)
  sucKhoe             String?  @db.Text
  isDangVien          Boolean? @default(false)
  ngayVaoCongDoan     DateTime? @db.Timestamp()
  bhxh                String?  @db.VarChar(20)
  doiTuongChinhSach   String?  @db.VarChar(100)
  bhyt                String?  @db.VarChar(20)
  ngayCapCccd         DateTime? @db.Timestamp()
  noiCapCccd          String?  @db.VarChar(5)
  sdt                 String?  @db.VarChar(20)
  createdAt           DateTime @default(now()) @db.Timestamp()
  updatedAt           DateTime @updatedAt @db.Timestamp()

  @@tableName("tcns_ly_lich")
  @@index([shcc])
  @@index([maNhanVien])
}
