{
  "uid": "kong-gateway",
  "title": "Kong API Gateway Monitoring",
  "description": "Traffic, latency and error rates from Kong Gateway via Prometheus",
  "tags": ["kong", "api-gateway"],
  "timezone": "browser",
  "refresh": "10s",
  "schemaVersion": 38,
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Tổng lượng request (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(kong_http_requests_total[1m])) by (service)",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP Status Code (2xx / 4xx / 5xx)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "2xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "4xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "5xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(kong_http_requests_total{code=~\"2..\"}[1m]))",
          "legendFormat": "2xx"
        },
        {
          "refId": "B",
          "expr": "sum(rate(kong_http_requests_total{code=~\"4..\"}[1m]))",
          "legendFormat": "4xx"
        },
        {
          "refId": "C",
          "expr": "sum(rate(kong_http_requests_total{code=~\"5..\"}[1m]))",
          "legendFormat": "5xx"
        }
      ]
    },
    {
      "id": 3,
      "title": "Latency P99 theo Service (ms)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "color": { "mode": "palette-classic" } }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum(rate(kong_latency_bucket{type=\"request\"}[1m])) by (le, service))",
          "legendFormat": "P99 {{service}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Active Connections (Nginx)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 100 },
            { "color": "red", "value": 500 }
          ]
        }}
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(kong_nginx_http_current_connections{state=\"active\"})",
          "legendFormat": "Active"
        }
      ]
    },
    {
      "id": 5,
      "title": "Tỷ lệ lỗi (%)",
      "type": "stat",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(kong_http_requests_total{code=~\"5..\"}[5m])) / sum(rate(kong_http_requests_total[5m])) * 100",
          "legendFormat": "Error rate"
        }
      ]
    },
    {
      "id": 6,
      "title": "Bandwidth (bytes/s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "Bps" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Ingress" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Egress" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(kong_bandwidth_bytes{direction=\"ingress\"}[1m]))",
          "legendFormat": "Ingress"
        },
        {
          "refId": "B",
          "expr": "sum(rate(kong_bandwidth_bytes{direction=\"egress\"}[1m]))",
          "legendFormat": "Egress"
        }
      ]
    }
  ]
}
